# Environment
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://pennywise:<db_password>@cluster0.cobrj.mongodb.net/pennywise?retryWrites=true&w=majority&appName=Cluster0

# JWT Secrets (change these in production!)
JWT_ACCESS_SECRET=pennywise-access-secret-change-in-production-32chars
JWT_REFRESH_SECRET=pennywise-refresh-secret-change-in-production-32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
